#!name=Eggy Proxy Rules
#!desc=个人代理规则插件：由 source/rules.yaml 自动生成
#!author=liueggy
#!homepage=https://github.com/liueggy/proxy-rules
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Proxy.png

[Rule]
# 自有服务器直连
IP-CIDR,167.71.221.110/32,DIRECT,no-resolve
IP-CIDR,168.144.136.246/32,DIRECT,no-resolve
IP-CIDR,167.71.214.73/32,DIRECT,no-resolve

# AI 服务
DOMAIN-SUFFIX,openai.com,AI
DOMAIN-SUFFIX,chatgpt.com,AI
DOMAIN-SUFFIX,oaistatic.com,AI
DOMAIN-SUFFIX,oaiusercontent.com,AI
DOMAIN-SUFFIX,anthropic.com,AI
DOMAIN-SUFFIX,claude.ai,AI
DOMAIN-SUFFIX,perplexity.ai,AI
DOMAIN-SUFFIX,gemini.google.com,AI

# GitHub
DOMAIN-SUFFIX,github.com,Proxy
DOMAIN-SUFFIX,githubusercontent.com,Proxy
DOMAIN-SUFFIX,githubassets.com,Proxy
DOMAIN-SUFFIX,github.io,Proxy

# Telegram
DOMAIN-SUFFIX,t.me,Proxy
DOMAIN-SUFFIX,telegram.org,Proxy
IP-CIDR,91.108.4.0/22,Proxy,no-resolve
IP-CIDR,91.108.8.0/22,Proxy,no-resolve
IP-CIDR,91.108.12.0/22,Proxy,no-resolve
IP-CIDR,91.108.16.0/22,Proxy,no-resolve
IP-CIDR,91.108.56.0/22,Proxy,no-resolve
IP-CIDR,149.154.160.0/20,Proxy,no-resolve

# Apple 服务
DOMAIN-SUFFIX,apple.com,Apple
DOMAIN-SUFFIX,icloud.com,Apple
DOMAIN-SUFFIX,cdn-apple.com,Apple

GEOIP,CN,DIRECT
FINAL,Proxy

[Rewrite]
# ^https?:\/\/example\.com\/ads reject

[MITM]
# hostname = example.com
